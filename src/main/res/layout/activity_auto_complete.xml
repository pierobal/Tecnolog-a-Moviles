<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainAuto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AutoCompleteActivity">

    <TextView
        android:id="@+id/txtTituloAuto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutoComplet"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txtEtiqueta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre:"
        android:textSize="18sp"
        android:layout_marginTop="80dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@+id/txtTituloAuto"
        app:layout_constraintStart_toStartOf="parent" />

    <AutoCompleteTextView
        android:id="@+id/txtPresidentes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Escriba un nombre"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@+id/txtEtiqueta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnActividad1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="AutoComplet"
            android:gravity="center"
            android:background="#03A9F4"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnActividad2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="TimePicker"
            android:gravity="center"
            android:background="#00BCD4"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnActividad3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DatePicker"
            android:gravity="center"
            android:background="#03A9F4"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>